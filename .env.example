# ============================================
# DeliveryFlow Environment Variables
# Copy this file to .env and fill in values
# ============================================

# PostgreSQL
POSTGRES_USER=deliveryflow
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=deliveryflow

# Backend Database URL (overridden in docker-compose for containerised DB)
DATABASE_URL=postgresql+asyncpg://deliveryflow:change_me_in_production@localhost:5432/deliveryflow

# Auth
SECRET_KEY=change-this-to-a-random-32-char-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Google OAuth 2.0
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Business Rules
STALE_DAYS_THRESHOLD=7

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
